# Copy to .env.local and fill in. None are required to RUN the app in dev
# (auth needs AUTH_SECRET; everything else has a safe dev fallback).

# --- Auth (required) ---------------------------------------------------------
# Random 32+ char string used to sign session + magic-link tokens.
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Random 32+ char string protecting the staff link-minting endpoint
# (GET /api/admin/signin-link) — used to hand a customer a sign-in link by LINE
# etc. when email bounces. Distinct from AUTH_SECRET (which signs tokens).
# Leave unset to disable the endpoint (503).
STAFF_LINK_SECRET=

# --- Shopify (headless backend) ---------------------------------------------
# The store holds products/variants/customers/orders/inventory/invoices.
# Admin API token from a custom app on the (dev) store. Server-side only.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2025-07

# --- Site URL (recommended in prod) -----------------------------------------
# Absolute base URL, used to build magic-link/quote URLs in emails.
# Leave blank in local dev (it falls back to the request host).
NEXT_PUBLIC_SITE_URL=

# --- Email via Resend (optional in dev) -------------------------------------
# Without a key, emails are printed to the server console instead of sent.
RESEND_API_KEY=
EMAIL_FROM="Hammond Button Works <onboarding@resend.dev>"
# Where contact / quote-form requests are delivered (general inbound-business
# inbox — ideally a Google Group so it can fan out to several people):
CONTACT_INBOX=contact@yourbrand.com

# --- Trade allowlist (optional) ---------------------------------------------
# Extra approved accounts beyond the seeded demo ones in src/lib/allowlist.ts.
# Comma-separated entries of "email|tier|Company Name".
# tier is one of: tier_standard | tier_volume | tier_partner
# Example:
# TRADE_ALLOWLIST=alice@brand.com|tier_volume|Brand Co, bob@maker.com|tier_partner|Maker Ltd
TRADE_ALLOWLIST=

# --- Cart: Snipcart (optional) ----------------------------------------------
# Public API key from the Snipcart dashboard. When unset, add-to-cart is
# disabled (the rest of the site works). Use the TEST key for the pilot.
NEXT_PUBLIC_SNIPCART_KEY=
# Provider switch for the cart abstraction (snipcart | stripe | none).
NEXT_PUBLIC_CART_PROVIDER=snipcart

# --- Quote → Google Sheet (optional) ----------------------------------------
# A Google Apps Script web-app URL that appends a row per quote. See README.
QUOTE_SHEET_WEBHOOK_URL=
